rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // =========================================================
    // USER PROFILE PHOTOS
    // Users can upload/read/delete their own profile photo
    // =========================================================
    match /users/{uid}/profile/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
                      request.auth.uid == uid &&
                      isValidImage() &&
                      request.resource.size < 5 * 1024 * 1024; // 5MB max

      function isValidImage() {
        return request.resource.contentType.matches('image/.*') &&
               request.resource.contentType in [
                 'image/jpeg',
                 'image/png',
                 'image/webp',
                 'image/gif'
               ];
      }
    }

    // =========================================================
    // VOICE RECORDINGS (Future: Edo speech input)
    // Premium users only
    // =========================================================
    match /voice/{uid}/{fileName} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if request.auth != null &&
                      request.auth.uid == uid &&
                      isPremiumUser() &&
                      isAudioFile() &&
                      request.resource.size < 10 * 1024 * 1024; // 10MB max

      function isAudioFile() {
        return request.resource.contentType.matches('audio/.*');
      }

      function isPremiumUser() {
        return firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.isPremium == true;
      }
    }

    // =========================================================
    // PUBLIC ASSETS (app icons, cultural images, etc.)
    // Read only — written by admins only
    // =========================================================
    match /public/{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }

    // =========================================================
    // DENY ALL OTHER ACCESS
    // =========================================================
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
