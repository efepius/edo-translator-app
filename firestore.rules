rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // =========================================================
    // HELPER FUNCTIONS
    // =========================================================

    // Check if the requester is authenticated
    function isAuth() {
      return request.auth != null;
    }

    // Check if the requester owns the document
    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    // Check if user is premium (checks Firestore user doc)
    function isPremium() {
      return isAuth() &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isPremium == true;
    }

    // Validate string length
    function validString(field, maxLen) {
      return field is string && field.size() > 0 && field.size() <= maxLen;
    }

    // =========================================================
    // USERS COLLECTION
    // Users can read/write their own profile
    // =========================================================
    match /users/{uid} {
      allow read: if isOwner(uid);
      allow create: if isOwner(uid) && validateNewUser();
      allow update: if isOwner(uid) && validateUserUpdate();
      allow delete: if false; // Only Cloud Functions can delete users

      function validateNewUser() {
        let d = request.resource.data;
        return d.keys().hasAll(['email', 'isPremium', 'subscriptionStatus', 'createdAt']) &&
               d.email is string &&
               d.isPremium == false &&
               d.subscriptionStatus == 'free';
      }

      function validateUserUpdate() {
        // Users can update display name and photo only
        // Subscription fields are managed by Cloud Functions only
        let allowed = ['displayName', 'photoURL', 'updatedAt', 'fcmToken'];
        return request.resource.data.diff(resource.data).affectedKeys().hasOnly(allowed);
      }
    }

    // =========================================================
    // TRANSLATIONS COLLECTION
    // Users can read their own translations
    // Only Cloud Functions can write (via admin SDK)
    // =========================================================
    match /translations/{translationId} {
      allow read: if isAuth() &&
                     resource.data.uid == request.auth.uid;
      allow create: if false; // Only Cloud Functions
      allow update: if false;
      allow delete: if isAuth() &&
                      resource.data.uid == request.auth.uid;
    }

    // =========================================================
    // FAVORITES COLLECTION
    // Users can CRUD their own favorites
    // =========================================================
    match /favorites/{favoriteId} {
      allow read: if isAuth() &&
                     resource.data.uid == request.auth.uid;
      allow create: if isAuth() &&
                       request.resource.data.uid == request.auth.uid &&
                       validateFavorite();
      allow update: if false; // Favorites are immutable once saved
      allow delete: if isAuth() &&
                       resource.data.uid == request.auth.uid;

      function validateFavorite() {
        let d = request.resource.data;
        return d.keys().hasAll(['uid', 'originalText', 'translatedText', 'direction']) &&
               validString(d.originalText, 2000) &&
               validString(d.translatedText, 2000) &&
               d.direction in ['edo-to-english', 'english-to-edo'];
      }
    }

    // =========================================================
    // USAGE COLLECTION
    // Users can read their own usage stats
    // Only Cloud Functions can write
    // =========================================================
    match /usage/{usageId} {
      allow read: if isAuth() &&
                     resource.data.uid == request.auth.uid;
      allow write: if false; // Only Cloud Functions
    }

    // =========================================================
    // PAYMENTS COLLECTION
    // Users can read their own payment history
    // Only Cloud Functions can write
    // =========================================================
    match /payments/{paymentId} {
      allow read: if isAuth() &&
                     resource.data.uid == request.auth.uid;
      allow write: if false; // Only Cloud Functions (Stripe webhook)
    }

    // =========================================================
    // DICTIONARY COLLECTION (public read, admin write)
    // The app's curated dictionary data
    // =========================================================
    match /dictionary/{wordId} {
      allow read: if true; // Public - anyone can read dictionary
      allow write: if false; // Admin only
    }

    // =========================================================
    // PREMIUM DICTIONARY ENTRIES
    // Only premium users can read
    // =========================================================
    match /dictionary_premium/{wordId} {
      allow read: if isPremium();
      allow write: if false; // Admin only
    }

    // =========================================================
    // APP CONFIG (public read)
    // Remote configuration values
    // =========================================================
    match /config/{configId} {
      allow read: if true;
      allow write: if false;
    }

    // =========================================================
    // DENY ALL OTHER ACCESS
    // =========================================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
